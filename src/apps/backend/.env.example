# Glimmer Backend — Local Environment Template
# Copy this file to .env and adjust values for your local setup.
# The app starts with sensible defaults even without this file.

# GLIMMER_DEBUG=false

# ── Network ──────────────────────────────────────────────────────
# Bind address: 0.0.0.0 for LAN/VPN access, 127.0.0.1 for localhost only
# GLIMMER_HOST=0.0.0.0
# GLIMMER_PORT=8000

# Allowed CORS origins (comma-separated).  Add your LAN IP or VPN
# hostname so the frontend can reach the backend from other devices.
# GLIMMER_CORS_ORIGINS=http://localhost:3000,http://192.168.1.x:3000

# ── Database ─────────────────────────────────────────────────────
# GLIMMER_DATABASE_URL=postgresql+psycopg://localhost:5432/glimmer_dev
# GLIMMER_TEST_DATABASE_URL=postgresql+psycopg://localhost:5432/glimmer_test

# ── Chrome / Gemini Adapter ──────────────────────────────────────
# Path to Google Chrome (macOS default shown)
# GLIMMER_CHROME_EXE_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Dedicated Chrome user-data directory for Gemini sessions
# GLIMMER_CHROME_USER_DATA_DIR=~/Library/Application Support/Glimmer/ChromeProfile

# Chrome profile directory name within user_data_dir
# GLIMMER_CHROME_PROFILE_NAME=Default

# Google account email (used for logging/diagnostics only)
# GLIMMER_CHROME_GOOGLE_ACCOUNT=you@gmail.com

# CDP remote debugging port
# GLIMMER_CHROME_REMOTE_DEBUGGING_PORT=9222

# Connection timeout (seconds)
# GLIMMER_CHROME_CONNECTION_TIMEOUT_SECONDS=30

# ── Research Adapter ─────────────────────────────────────────────
# Deep Research timeout (minutes)
# GLIMMER_RESEARCH_RESEARCH_TIMEOUT_MINUTES=60

# Daily rate limit for research jobs (0 = no limit)
# GLIMMER_RESEARCH_DAILY_RATE_LIMIT=19

# Expert advice chat timeout (seconds)
# GLIMMER_RESEARCH_CHAT_RESPONSE_TIMEOUT_SECONDS=300

# Default Gemini mode for expert advice: Fast, Thinking, Pro
# GLIMMER_RESEARCH_DEFAULT_CHAT_MODE=Pro

# ── LLM Inference (Workstream I) ──────────────────────────────────
# OpenAI-compatible endpoint (LM Studio default)
# GLIMMER_INFERENCE_BASE_URL=http://127.0.0.1:1234/v1

# API key — LM Studio accepts any non-empty string
# GLIMMER_INFERENCE_API_KEY=lm-studio

# Model name as reported by the provider's /v1/models
# GLIMMER_INFERENCE_MODEL_NAME=google/gemma-4-31b

# Generation defaults
# GLIMMER_INFERENCE_DEFAULT_TEMPERATURE=0.3
# GLIMMER_INFERENCE_DEFAULT_MAX_TOKENS=2000

# Timeouts (seconds)
# GLIMMER_INFERENCE_CONNECT_TIMEOUT_SECONDS=5.0
# GLIMMER_INFERENCE_READ_TIMEOUT_SECONDS=120.0
# GLIMMER_INFERENCE_HEALTH_TIMEOUT_SECONDS=5.0

# Per-task LLM toggles — for operational tuning.
# Disable individual tasks to fall back to deterministic logic when the
# LLM adds unacceptable latency or output quality does not yet meet
# operational expectations.  All default to True (LLM-first).
# GLIMMER_INFERENCE_LLM_CLASSIFICATION_ENABLED=true
# GLIMMER_INFERENCE_LLM_EXTRACTION_ENABLED=true
# GLIMMER_INFERENCE_LLM_PRIORITIZATION_ENABLED=true
# GLIMMER_INFERENCE_LLM_DRAFTING_ENABLED=true
# GLIMMER_INFERENCE_LLM_BRIEFING_ENABLED=true

# ── Telegram Operator Alerts ─────────────────────────────────────
# Bot token for sending system health alerts to the operator.
# This is an internal operational alert channel, not user-facing messaging.
# GLIMMER_TELEGRAM_BOT_TOKEN=
# GLIMMER_TELEGRAM_OPERATOR_CHAT_ID=

