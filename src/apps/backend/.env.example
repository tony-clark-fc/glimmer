# Glimmer Backend — Local Environment Template
# Copy this file to .env and adjust values for your local setup.
# The app starts with sensible defaults even without this file.

# GLIMMER_DEBUG=false

# ── Network ──────────────────────────────────────────────────────
# Bind address: 0.0.0.0 for LAN/VPN access, 127.0.0.1 for localhost only
# GLIMMER_HOST=0.0.0.0
# GLIMMER_PORT=8000

# Allowed CORS origins (comma-separated).  Add your LAN IP or VPN
# hostname so the frontend can reach the backend from other devices.
# GLIMMER_CORS_ORIGINS=http://localhost:3000,http://192.168.1.x:3000

# ── Database ─────────────────────────────────────────────────────
# GLIMMER_DATABASE_URL=postgresql+psycopg://localhost:5432/glimmer_dev
# GLIMMER_TEST_DATABASE_URL=postgresql+psycopg://localhost:5432/glimmer_test

